---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="teaching-practice-shell">
    <div class="shell-glow shell-glow--left" aria-hidden="true"></div>
    <div class="shell-glow shell-glow--right" aria-hidden="true"></div>
    <slot />
  </div>
</BaseLayout>

<style>
  .teaching-practice-shell {
    position: relative;
    width: 100%;
    min-height: calc(100dvh - var(--navbar-height));
    box-sizing: border-box;
    overflow-x: clip;
  }

  .shell-glow {
    position: absolute;
    width: min(42vw, 520px);
    height: min(42vw, 520px);
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  .shell-glow--left {
    top: 8%;
    left: -12%;
    background: color-mix(in srgb, var(--accent-color) 28%, transparent);
  }

  .shell-glow--right {
    bottom: 6%;
    right: -10%;
    background: color-mix(in srgb, #ebb5a5 22%, transparent);
  }

  .teaching-practice-shell > :global(:not(.shell-glow)) {
    position: relative;
    z-index: 1;
  }
</style>
