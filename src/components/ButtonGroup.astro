---
interface Props {
  direction?: string;
}

const { direction = "row" } = Astro.props;
---

<div class="button-group">
  <slot />
</div>

<style define:vars={{ direction }}>
  .button-group {
    display: flex;
    flex-direction: var(--direction);

    gap: clamp(2px, 0.5em, 2vw);
  }

  @media (max-width: 400px) {
    .button-group {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      gap: 0.75rem;
    }
  }
</style>
