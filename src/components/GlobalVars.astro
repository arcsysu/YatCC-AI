---
// import "../styles/global.css";
---

<style is:global>
  :root {
    /* 默认明亮模式 */
    --bg-color: #ffffff;
    --text-color: #1a1a1a;
    --accent-color: #3b82f6;
  }

  [data-theme="dark"] {
    /* 黑暗模式 */
    --bg-color: #020203;
    --text-color: #f8fafc;
    --accent-color: #60a5fa;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-color);
    transition:
      background-color 0.3s ease,
      color 0.3s ease;
  }
</style>
