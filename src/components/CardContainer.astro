<div class="card-container">
  <slot />
</div>

<style>
  .card-container {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }

  @media (max-width: 1080px) {
    .card-container {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .card-container {
      grid-template-columns: 1fr;
    }
  }
</style>
