---
import Link from "../Link.astro";
import NavSplitLink from "../NavSplitLink.astro";
import NavDropdown from "../NavDropdown.astro";
import DarkLightButton from "../DarkLightButton.astro";
import { getLangFromUrl, tOfUrl, useTranslatedPath } from "@/i18n/utils";

interface Props {
  layout?: "inline" | "stacked";
}

const { layout = "inline" } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = tOfUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const dropdownToggle = layout === "stacked" ? "click" : "hover";
const topDropdownDirection = layout === "stacked" ? "auto" : "down";
---

<div class:list={["yatcc-nav-menu", layout === "stacked" && "yatcc-nav-menu--stacked"]}>
  <Link href="https://ol.yatcc.arcsysu.cn/">&#128640; Get Started</Link>
  <NavDropdown toggle={dropdownToggle} direction={topDropdownDirection} compact>
    <div slot="title">{t("nav.implementation")}</div>
    <NavSplitLink
      leftHref="https://ol.yatcc.arcsysu.cn/"
      leftLabel="OL Lab"
      rightHref="https://ol.yatcc.arcsysu.cn/api/doc/"
      rightLabel={t("nav.olLabApi")}
      groupLabel={`OL Lab / ${t("nav.olLabApi")}`}
    />
    <Link href="https://portal.aihub.arcsysu.cn">AI Hub</Link>
    <Link href="#">DT Fab</Link>
  </NavDropdown>
  <NavDropdown toggle={dropdownToggle} direction={topDropdownDirection}>
    <div slot="title">{t("nav.team")}</div>
    <Link href="https://arcsysu.tech/people">arcsysu</Link>
    <Link href="https://docs.yatcc-ai.com/contributors/">{t("nav.contributors")}</Link>
  </NavDropdown>
  <NavDropdown toggle={dropdownToggle} direction={topDropdownDirection}>
    <div slot="title">{t("nav.cases")}</div>
    <Link href={translatePath("/teaching-practice")}>{t("nav.teaching")}</Link>
    <Link href="https://arcsysu.tech/">{t("nav.research")}</Link>
  </NavDropdown>
  <div class="ai-trigger-container">
    <DarkLightButton href="">{t("nav.ask_ai")}</DarkLightButton>
  </div>
</div>

<style>
  .yatcc-nav-menu {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: nowrap;
  }

  .yatcc-nav-menu:not(.yatcc-nav-menu--stacked) :global(.popup-card) {
    overflow: visible;
  }

  .yatcc-nav-menu:not(.yatcc-nav-menu--stacked) :global(.dropdown-left > .popup-wrapper) {
    z-index: 110;
  }

  .yatcc-nav-menu--stacked {
    flex-direction: column;
    align-items: stretch;
    gap: 0.35rem;
    width: 100%;
    overflow: visible;
  }

  .yatcc-nav-menu--stacked :global(.popup-card) {
    overflow: visible;
  }

  .yatcc-nav-menu--stacked :global(.dropdown-container) {
    width: 100%;
  }

  .yatcc-nav-menu--stacked :global(.dropdown-trigger) {
    width: 100%;
    justify-content: space-between;
  }

  .yatcc-nav-menu--stacked .ai-trigger-container {
    width: 100%;
  }

  .yatcc-nav-menu--stacked .ai-trigger-container :global(.button-container) {
    width: 100%;
  }

  .yatcc-nav-menu--stacked .ai-trigger-container :global(.button) {
    width: 100%;
  }


</style>
