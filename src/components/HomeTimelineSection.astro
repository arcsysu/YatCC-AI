---
import type { BlogEntry, SiteLang } from "@/lib/blog";
import { formatBlogDate } from "@/lib/blog";
import Button from "@/components/Button.astro";

interface Props {
  lang: SiteLang;
  posts: BlogEntry[];
}

const { lang, posts } = Astro.props;

const copy = {
  zh: {
    eyebrow: "Timeline / News",
    title: "近期动态",
    description:
      "用一条时间线把最近的更新节点串起来。点开任意标题，就能进入对应博客页。",
    empty: "当前还没有新闻，稍后再来看看。",
    cta: "查看全部动态",
    link: "查看节点",
  },
  en: {
    eyebrow: "Timeline / News",
    title: "Latest Updates",
    description:
      "A single timeline connects the latest milestones. Open any title to jump to the matching blog post.",
    empty: "No news posts yet. Check back soon.",
    cta: "Browse all posts",
    link: "Open node",
  },
} as const;

const text = copy[lang];
const featuredPosts = posts.slice(0, 12);
---

<section id="news" class="timeline-section">
  <div class="timeline-heading">
    <span>{text.eyebrow}</span>
    <h2>{text.title}</h2>
    <!-- <p>{text.description}</p> -->
    <Button href={lang === "zh" ? "/zh/blog" : "/en/blog"}>{text.cta}</Button>
  </div>

  {
    featuredPosts.length ? (
      <ol class="timeline-list">
        {featuredPosts.map((post, index) => {
          const href =
            lang === "zh" ? `/zh/blog/${post.slug}` : `/en/blog/${post.slug}`;

          return (
            <li
              class:list={[
                "timeline-item",
                index % 2 === 1 && "timeline-item-reverse",
              ]}
            >
              <div class="timeline-entry">
                <h3>
                  <a href={href}>{post.data.title}</a>
                </h3>
                <time
                  class="timeline-date"
                  datetime={post.data.date.toISOString()}
                >
                  {formatBlogDate(post.data.date, lang)}
                </time>
                <a class="timeline-link" href={href}>
                  {text.link}
                </a>
              </div>
              <div class="timeline-axis" aria-hidden="true">
                <span class="timeline-node" />
              </div>
            </li>
          );
        })}
      </ol>
    ) : (
      <p class="timeline-empty">{text.empty}</p>
    )
  }
</section>

<style>
  .timeline-section {
    width: 100%;
    margin: 0;
    padding: clamp(1.6rem, 4vw, 2.8rem);
    border-radius: 2.25rem;
    border: 1px solid var(--border-color);
    background:
      radial-gradient(
        circle at top left,
        color-mix(in srgb, var(--accent-color) 14%, transparent),
        transparent 26%
      ),
      linear-gradient(
        160deg,
        color-mix(in srgb, var(--accent-color) 7%, transparent),
        transparent 28%
      ),
      color-mix(in srgb, var(--bg-color) 90%, var(--bg-color-dimmer));
    box-sizing: border-box;
    box-shadow: 0 28px 60px
      color-mix(in srgb, var(--anti-bg-color) 7%, transparent);
  }

  .timeline-heading {
    display: grid;
    gap: 0.85rem;
    margin-bottom: 2rem;
  }

  .timeline-heading span {
    color: var(--sub-text-color);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }

  .timeline-heading h2 {
    margin: 0;
  }

  .timeline-heading h2 {
    font-size: clamp(1.8rem, 4vw, 3rem);
  }

  .timeline-heading p,
  .timeline-empty {
    margin: 0;
    color: var(--sub-text-color);
    line-height: 1.75;
  }

  .timeline-heading :global(.button-container) {
    width: fit-content;
  }

  .timeline-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0 0;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.9rem;
    position: relative;
    align-items: center;
  }

  .timeline-list::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    transform: translateY(-50%);
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--accent-color) 35%, transparent),
      color-mix(in srgb, var(--accent-color) 68%, var(--border-color)),
      color-mix(in srgb, var(--accent-color) 35%, transparent)
    );
  }

  .timeline-item {
    min-width: 0;
    display: grid;
    grid-template-rows: 1fr 28px 1fr;
    position: relative;
  }

  .timeline-entry {
    display: grid;
    gap: 0.45rem;
    align-content: end;
    min-height: 104px;
    padding: 0.35rem 0.2rem;
    transition:
      transform 0.22s ease,
      opacity 0.22s ease;
  }

  .timeline-entry:hover {
    transform: translateY(-2px);
  }

  .timeline-item-reverse .timeline-entry {
    grid-row: 3;
    align-content: start;
  }

  .timeline-item:not(.timeline-item-reverse) .timeline-entry {
    grid-row: 1;
  }

  .timeline-entry h3 {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.35;
  }

  .timeline-entry h3 a {
    color: var(--text-color);
    text-decoration: none;
  }

  .timeline-entry h3 a:hover {
    color: var(--accent-color);
  }

  .timeline-date,
  .timeline-link {
    color: var(--sub-text-color);
    font-size: 0.8rem;
    letter-spacing: 0.03em;
  }

  .timeline-date {
    display: block;
  }

  .timeline-link {
    width: fit-content;
    text-decoration: none;
    color: var(--accent-color);
    font-weight: 600;
  }

  .timeline-link:hover {
    text-decoration: underline;
  }

  .timeline-axis {
    grid-row: 2;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .timeline-axis::before,
  .timeline-axis::after {
    content: "";
    position: absolute;
    left: 50%;
    width: 1px;
    transform: translateX(-50%);
    background: color-mix(
      in srgb,
      var(--accent-color) 35%,
      var(--border-color)
    );
  }

  .timeline-item:not(.timeline-item-reverse) .timeline-axis::before {
    top: -20px;
    bottom: 50%;
  }

  .timeline-item-reverse .timeline-axis::after {
    top: 50%;
    bottom: -20px;
  }

  .timeline-node {
    z-index: 1;
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: var(--accent-color);
    border: 4px solid var(--bg-color);
    box-shadow:
      0 0 0 6px color-mix(in srgb, var(--accent-color) 12%, transparent),
      0 8px 18px color-mix(in srgb, var(--accent-color) 24%, transparent);
  }

  .timeline-item:nth-child(n + 7) {
    display: none;
  }

  @media (max-width: 1180px) {
    .timeline-list {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .timeline-item:nth-child(n + 6) {
      display: none;
    }
  }

  @media (max-width: 980px) {
    .timeline-list {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .timeline-item:nth-child(n + 5) {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .timeline-list {
      min-width: 0;
      display: grid;
      grid-auto-flow: row;
      grid-auto-columns: auto;
      grid-template-columns: 1fr;
      gap: 0.8rem;
      padding: 0;
      margin-top: 1.25rem;
    }

    .timeline-list::before {
      left: 12px;
      right: auto;
      top: 0;
      bottom: 0;
      width: 2px;
      height: auto;
      transform: none;
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--accent-color) 35%, transparent),
        color-mix(in srgb, var(--accent-color) 68%, var(--border-color)),
        color-mix(in srgb, var(--accent-color) 35%, transparent)
      );
    }

    .timeline-item,
    .timeline-item-reverse {
      min-width: 0;
      grid-template-columns: 24px minmax(0, 1fr);
      grid-template-rows: auto;
      gap: 0.95rem;
      align-items: start;
    }

    .timeline-item:nth-child(n + 5),
    .timeline-item:nth-child(n + 6),
    .timeline-item:nth-child(n + 7) {
      display: grid;
    }

    .timeline-item:not(.timeline-item-reverse) .timeline-entry,
    .timeline-entry,
    .timeline-item-reverse .timeline-entry {
      grid-column: 2;
      grid-row: auto;
      min-height: auto;
      align-content: start;
      padding: 0 0 1rem;
    }

    .timeline-axis,
    .timeline-item-reverse .timeline-axis {
      grid-column: 1;
      grid-row: auto;
      min-height: 100%;
      align-items: flex-start;
      justify-content: center;
      padding-top: 0.28rem;
    }

    .timeline-axis::before,
    .timeline-axis::after {
      display: none;
    }

    .timeline-node {
      width: 14px;
      height: 14px;
      border-width: 3px;
      box-shadow:
        0 0 0 4px color-mix(in srgb, var(--accent-color) 12%, transparent),
        0 6px 14px color-mix(in srgb, var(--accent-color) 20%, transparent);
    }

    .timeline-item:last-child .timeline-entry {
      padding-bottom: 0;
    }
  }
</style>
