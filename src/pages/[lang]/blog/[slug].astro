---
export async function getStaticPaths() {
  const legacyBlogSlugs = [
    "weekly-newsletter-zh",
    "weekly-newsletter-en",
    "teaching-sprint-en",
    "teaching-sprint-zh",
    "platform-roadmap-en",
    "platform-roadmap-zh",
    "codespaces-preview-zh",
    "codespaces-preview-en",
    "demo-test-homepage-en",
    "demo-test-homepage-zh",
  ];

  return (["zh", "en"] as const).flatMap((lang) =>
    legacyBlogSlugs.map((slug) => ({
      params: { lang, slug },
    })),
  );
}

const { lang } = Astro.params;

return Astro.redirect(`/${lang}/news`);
---
