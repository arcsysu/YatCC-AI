---
import HomePageShell from "@/components/HomePageShell.astro";
import HomeHero from "@/components/HomeHero.astro";
import HomeStatsSection from "@/components/HomeStatsSection.astro";
import CardContainer from "@/components/CardContainer.astro";
import Card from "@/components/Card.astro";
import HomeFeatureSection from "@/components/HomeFeatureSection.astro";
import FeatureDisplayPageFeature from "@/components/FeatureDisplayPageFeature.astro";
import HomeTimelineSection from "@/components/HomeTimelineSection.astro";
import imgUseCodespaces from "@public/use-codespaces.gif";
import imgUseOl from "@public/use-ol.gif";
import imgAiHubShowcase from "@assets/ai-hub-showcase.png";
import { getLangFromUrl } from "@/i18n/utils";
import { getLatestNews, getNewsEntries } from "@/lib/news";

const lang = getLangFromUrl(Astro.url);
const t = <T,>(value: { zh: T; en: T }) => value[lang];
const latestNews = getLatestNews(await getNewsEntries(lang), 5);
---

<HomePageShell>
  <HomeHero
    slot="hero"
    title="YatCC AI"
    subtitle={t({
      zh: "贯通“应用—系统—算力”的全栈式、一体化智能服务平台",
      en: "One-stop intelligent platform from apps to compute.",
    })}
    rampLabel={t({
      zh: "⚡ RAMP 模型榜单",
      en: "⚡ RAMP Leaderboard",
    })}
    rampHref="https://ramp.nexa-lang.com/"
    primaryLabel={t({
      zh: "🔨 进入平台",
      en: "🔨 Get Started",
    })}
    primaryHref="https://ol.yatcc.arcsysu.cn"
    tertiaryLabel={t({
      zh: "🎓 2026编译实践",
      en: "🎓 2026 Compiler",
    })}
    tertiaryHref="https://yatcc-ai.com/teach/s2026.html"
  />

  <HomeStatsSection slot="stats" lang={lang} />

  <CardContainer slot="cards">
    <Card icon="📦" title={t({ zh: "设计模块化", en: "Highly Modular" })}>
      {t({
        zh: "以前沿技术体系为驱动，构建高内聚、低耦合的模块化架构，支持组件级扩展与能力复用，为复杂系统构建提坚实健技术底座",
        en: "Decouple compiler frontend and backend logic with a clean architecture that stays extensible for both teaching and research.",
      })}
    </Card>
    <Card icon="🌐" title={t({ zh: "体验现代化", en: "Automated Evaluation" })}>
      {t({
        zh: "提供容器化支持，打造『零配置』Web 化实践平台，用户无需本地部署与复杂环境搭建，打开浏览器即开即用，让计算触手可及",
        en: "Built-in unit tests and dual-mode automated evaluation streamline workflows across both local and cloud environments.",
      })}
    </Card>
    <Card icon="🤖" title={t({ zh: "过程智能化", en: "Deep LLM Integration" })}>
      {t({
        zh: "深度融合 DeepSeek、OpenClaw 等先进模型及框架，提供统一 AI Hub 能力入口，一键进入 Vibe Coding 和 Agent 应用",
        en: "Integrate models such as DeepSeek into a zero-setup web platform so learners can start exploring compilers directly in the browser.",
      })}
    </Card>
    <Card icon="🦾" title={t({ zh: "资源聚合化", en: "End-to-End Intelligence" })}>
      {t({
        zh: "围绕平台能力构建多层次资源体系，提供服务接口、技术文档、引导教程、智能助手等完整支持链路，持续优化提升用户实践体验",
        en: "Support the full compiler-building workflow with intelligent automation and enable AI-driven innovation throughout the pipeline.",
      })}
    </Card>
  </CardContainer>

  <HomeFeatureSection slot="ol-lab" title="OL LAB" direction="left">
    <FeatureDisplayPageFeature
      image={imgUseCodespaces}
      alt={t({ zh: "OL LAB 便捷化演示", en: "OL LAB accessibility demo" })}
    >
      <span slot="title">{t({ zh: "便捷化", en: "Accessible" })}</span>
      <span slot="description">
        {t({
          zh: "通过云端开发环境与预置工具链，快速进入系统开发状态，减少本地环境搭建与排障成本",
          en: "Start quickly with cloud development environments and preconfigured toolchains, without spending time on local setup.",
        })}
      </span>
    </FeatureDisplayPageFeature>
    <FeatureDisplayPageFeature
      image={imgUseOl}
      alt={t({ zh: "OL LAB 自动化演示", en: "OL LAB automation demo" })}
    >
      <span slot="title">{t({ zh: "自动化", en: "Automated" })}</span>
      <span slot="description">
        {t({
          zh: "开发、测试、部署、运行，端到端流程自动化闭环，让实践过程更稳定、更高效、更可复现",
          en: "Unify submission, evaluation, and feedback into one smooth workflow for more reliable and reproducible lab experiences.",
        })}
      </span>
    </FeatureDisplayPageFeature>
    <FeatureDisplayPageFeature
      image={imgUseCodespaces}
      alt={t({ zh: "OL LAB 智能化演示", en: "OL LAB intelligence demo" })}
    >
      <span slot="title">{t({ zh: "智能化", en: "Intelligent" })}</span>
      <span slot="description">
        {t({
          zh: "将 AI 能力嵌入教学与科研场景，在系统开发构建过程中提供全程辅助，推动智能范式变革",
          en: "Embed AI assistance into compiler education and practice to provide more natural guidance during implementation and experimentation.",
        })}
      </span>
    </FeatureDisplayPageFeature>
  </HomeFeatureSection>

  <HomeFeatureSection slot="ai-hub" title="AI Hub" direction="right">
    <FeatureDisplayPageFeature
      image={imgAiHubShowcase}
      alt={t({ zh: "AI Hub 平台展示", en: "AI Hub platform showcase" })}
    >
      <span slot="title">{t({ zh: "统一模型网关", en: "Unified Model Gateway" })}</span>
      <span slot="description">
        {t({
          zh: "基于 LiteLLM 提供统一 LLM Gateway，将多模型调用抽象为一致接口，实现跨模型能力的无缝接入与灵活切换",
          en: "Provide a LiteLLM-based gateway that unifies multi-model access behind a consistent interface for switching and integration.",
        })}
      </span>
    </FeatureDisplayPageFeature>
    <FeatureDisplayPageFeature
      image={imgAiHubShowcase}
      alt={t({ zh: "AI Hub 平台展示", en: "AI Hub platform showcase" })}
    >
      <span slot="title">{t({ zh: "密钥访问控制", en: "Access Control" })}</span>
      <span slot="description">
        {t({
          zh: "面向项目与用户提供体系化的认证鉴权、虚拟密钥与细粒度访问控制机制，构建开放、共享、可控的先进性服务能力",
          en: "Support authentication, virtual keys, and project-level access control so model services remain manageable and clearly isolated.",
        })}
      </span>
    </FeatureDisplayPageFeature>
    <FeatureDisplayPageFeature
      image={imgAiHubShowcase}
      alt={t({ zh: "AI Hub 平台展示", en: "AI Hub platform showcase" })}
    >
      <span slot="title">{t({ zh: "用量成本观测", en: "Usage Visibility" })}</span>
      <span slot="description">
        {t({
          zh: "依托统一管理控制台观测 Token 使用、调用频次与项目级开销，支持精细化管理模型使用、预算消耗与平台活跃度",
          en: "Track tokens, requests, and project-level spending through the admin console to better understand usage, activity, and cost.",
        })}
      </span>
    </FeatureDisplayPageFeature>
  </HomeFeatureSection>

  <HomeTimelineSection slot="news" lang={lang} news={latestNews} />
</HomePageShell>
