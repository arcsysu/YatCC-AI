---
import TeachingPracticePageShell from "@/components/TeachingPracticePageShell.astro";
import TeachingHero from "@/components/TeachingHero.astro";
import TeachingOverview from "@/components/TeachingOverview.astro";
import CardContainer from "@/components/CardContainer.astro";
import Card from "@/components/Card.astro";
import TeachingShowcase from "@/components/TeachingShowcase.astro";
import { getLangFromUrl } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = <T,>(value: { zh: T; en: T }) => value[lang];
---

<TeachingPracticePageShell>
  <TeachingHero
    slot="hero"
    title={t({
      zh: "教学实践",
      en: "Teaching Practice",
    })}
    subtitle={t({
      zh: "面向课程建设、实验组织与智能化助教协作的教学实践展示页，后续可持续补充真实案例、课程成果与平台数据。",
      en: "A showcase page for course delivery, lab orchestration, and AI-assisted teaching workflows, ready to be filled with real cases later.",
    })}
    primaryLabel={t({
      zh: "查看平台",
      en: "Open Platform",
    })}
    primaryHref="https://ol.yatcc.arcsysu.cn"
    secondaryLabel={t({
      zh: "相关文档",
      en: "Read Docs",
    })}
    secondaryHref="https://docs.yatcc-ai.com"
  />

  <TeachingOverview
    slot="overview"
    eyebrow={t({
      zh: "内容总览",
      en: "Overview",
    })}
    title={t({
      zh: "面向课程落地的实践展示模块",
      en: "Practice-ready teaching showcase modules",
    })}
    description={t({
      zh: "该页面延续主页的视觉语言，并预留清晰的占位区域，后续可以逐步补充课程案例、教学资料、成果总结与平台数据。",
      en: "This page follows the home page visual language and leaves clear placeholder zones for later course cases, teaching assets, outcome summaries, and platform metrics.",
    })}
  />

  <CardContainer slot="cards">
    <Card icon="🧪" title={t({ zh: "课程实验编排", en: "Course Lab Design" })}>
      {t({
        zh: "支持从实验发布、环境准备到结果回收的统一组织，方便后续接入具体课程案例与时间线。",
        en: "Organize publishing, environment setup, and result collection in one flow, with room for real course case details later.",
      })}
    </Card>
    <Card icon="🧑‍🏫" title={t({ zh: "教学流程协同", en: "Teaching Collaboration" })}>
      {t({
        zh: "覆盖教师、助教与学生三类角色的协作流程，可在后续补充班级规模、任务拆分与评分策略。",
        en: "Cover teacher, TA, and student collaboration workflows, with placeholders for class scale, task breakdown, and grading strategy.",
      })}
    </Card>
    <Card icon="📊" title={t({ zh: "过程数据展示", en: "Process Insights" })}>
      {t({
        zh: "预留实验完成率、常见问题分布与平台活跃度等数据板块，便于后续沉淀真实教学指标。",
        en: "Reserve space for completion rate, issue distribution, and platform activity metrics once real teaching data is available.",
      })}
    </Card>
  </CardContainer>

  <Fragment slot="showcases">
    <TeachingShowcase
      eyebrow={t({ zh: "实践场景 A", en: "Scenario A" })}
      title={t({ zh: "编译原理课程实验组织", en: "Compiler Course Lab Delivery" })}
      description={t({
        zh: "这里后续可展示课程简介、实验阶段、平台接入方式，以及学生从准备到提交的完整实践路径。",
        en: "This section can later introduce the course, lab milestones, platform onboarding, and the end-to-end student workflow.",
      })}
      placeholderBadge={t({ zh: "占位", en: "Placeholder" })}
      placeholderTitle={t({ zh: "待补充案例材料", en: "Case Materials Coming Soon" })}
      placeholderDescription={t({
        zh: "可在这里放置课程截图、实验界面、成果海报或关键数据概览。",
        en: "Use this area for course screenshots, lab interfaces, posters, or a concise data summary.",
      })}
      align="left"
    >
      <li>{t({ zh: "占位：课程背景与开课信息", en: "Placeholder: course background and schedule" })}</li>
      <li>{t({ zh: "占位：实验阶段拆分与目标", en: "Placeholder: lab phases and goals" })}</li>
      <li>{t({ zh: "占位：学生使用流程与反馈摘要", en: "Placeholder: student workflow and feedback summary" })}</li>
    </TeachingShowcase>

    <TeachingShowcase
      eyebrow={t({ zh: "实践场景 B", en: "Scenario B" })}
      title={t({ zh: "智能助教与答疑支持", en: "AI TA and Support Workflow" })}
      description={t({
        zh: "这里后续可补充 AI 助教、实验指导与常见问题归纳等内容，说明平台如何提升教学支撑效率。",
        en: "This section can later describe AI teaching assistants, lab guidance, and FAQ support to show how the platform improves teaching operations.",
      })}
      placeholderBadge={t({ zh: "占位", en: "Placeholder" })}
      placeholderTitle={t({ zh: "待补充交互演示", en: "Interaction Demo Coming Soon" })}
      placeholderDescription={t({
        zh: "可在这里放置对话示例、助教工作流示意图，或阶段性使用成效。",
        en: "Use this area for dialogue samples, TA workflow diagrams, or early usage outcomes.",
      })}
      align="right"
    >
      <li>{t({ zh: "占位：问答场景与助教协作方式", en: "Placeholder: Q&A scenarios and TA workflow" })}</li>
      <li>{t({ zh: "占位：AI 辅助能力接入说明", en: "Placeholder: AI capability integration notes" })}</li>
      <li>{t({ zh: "占位：师生反馈与迭代计划", en: "Placeholder: teacher and student feedback" })}</li>
    </TeachingShowcase>

    <TeachingShowcase
      eyebrow={t({ zh: "实践场景 C", en: "Scenario C" })}
      title={t({ zh: "课程成果与推广复用", en: "Outcomes and Reuse" })}
      description={t({
        zh: "这里后续可展示课程成果复盘、教学资源沉淀与跨课程复用方式，作为案例页的长期扩展区域。",
        en: "This section can later show course outcomes, reusable assets, and cross-course adoption as the page grows over time.",
      })}
      placeholderBadge={t({ zh: "占位", en: "Placeholder" })}
      placeholderTitle={t({ zh: "待补充成果展示", en: "Outcome Showcase Coming Soon" })}
      placeholderDescription={t({
        zh: "可在这里展示项目报告、作品截图、课程评价或推广材料。",
        en: "Use this area for reports, project snapshots, course evaluations, or outreach materials.",
      })}
      align="left"
    >
      <li>{t({ zh: "占位：课程成果总结", en: "Placeholder: outcome summary" })}</li>
      <li>{t({ zh: "占位：资源复用与共享方式", en: "Placeholder: resource sharing approach" })}</li>
      <li>{t({ zh: "占位：后续建设计划", en: "Placeholder: future roadmap" })}</li>
    </TeachingShowcase>
  </Fragment>
</TeachingPracticePageShell>
